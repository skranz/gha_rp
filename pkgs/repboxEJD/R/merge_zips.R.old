# Sometimes supplements are distributed over multiple zip files
# Instead of incorporating directly support for multiple zip file handling
# it seems easier to merge multiple zip files into one

ejd_merge_all_zips = function() {
  zip_dirs = c("~/downloads","~/puppeteer/downloads_ms","~/puppeteer/downloads_oi","~/selenium/downloads")

  zip_files = list.files(zip_dirs,full.names = TRUE, recursive = TRUE)

  zip_df = tibble(
    artid = NA_character_,
    zip_id = tools::file_path_sans_ext(basename(zip_files)),
    file = zip_files,
    dir = dirname(zip_files),
    mb = file.size(zip_files) / 1e6,
    from_oi = endsWith(dir, "_oi"),
    from_ms = endsWith(dir, "_ms"),
    from_direct = endsWith(dir, "downloads")
  )

  artid_rx = "^[a-z]+_[0-9]+_[0-9]+_[0-9]+"
  multi_rx = paste0(artid_rx, "__[0-9]+$")
  is_multi_zip = stringi::stri_detect_regex(zip_df$zip_id, multi_rx)
  mu_df = zip_df[is_multi_zip,]

  mu_df$artid = str.left.of(mu_df$zip_id,"__")

  mu_df = mu_df[!mu_df$artid %in% zip_df$zip_id,]

  ne_df = mu_df %>%
    select(artid,dir, file) %>%
    nest(files=file)



  i = 1
  for (i in seq_len(NROW(ne_df))) {
    output_file = file.path(ne_df$dir[[i]],paste0(ne_df$artid[[i]],".zip"))
    if (file.exists(output_file)) {
      cat("\n", output_file, " exists.")
      next
    }
    next


    input_files = unlist(ne_df$files[[i]])
    if (length(input_files)==1) next
    cat(paste0("\nMerge ", length(input_files), " zips to ", output_file))
    merge_zip_files(input_files = input_files, output_file = output_file)
    cat(" ", round(file.size(ouput_file) / 1e6,2), " MB\n")
  }
  #file.exists(ouput_file)
  #file.size(ouput_file) / 1e6
  #unzip(output_file, exdir = "~/repbox/temp/zip")
  #file.remove(output_file)
}

merge_zip_files = function(input_files, output_file) {
  cmd = paste0('zipmerge "', output_file, '" ', paste0('"',input_files,'"', collapse=" "))
  system(cmd)

}
